# Environment variables for dame.is
#
# Copy to `.env` (git-ignored) and fill in. Nothing here is needed just to run
# `npm run dev` / `npm run build:offline` against an existing snapshot — these
# only matter for the PDS-writing scripts (scripts/), the serverless functions
# (api/), and the are.na mirror (arena-mirror/). Values below are placeholders.
#
# A note on the two naming conventions: the mirror/import scripts read the
# BSKY_*/ATP_* pair, while the portfolio/guestbook scripts read the DAME_*/APP_*
# pair. They're historical aliases for the same credentials — set whichever the
# script you're running looks for (both is fine).

# --- AT Protocol credentials (mirror + import scripts, cron functions) --------
# Handle (or DID) to authenticate as. Falls back to the site handle (dame.is).
# Read by scripts/mirror-inaturalist.mjs, scripts/mirror-arena.mjs,
# scripts/import-resume.mjs and api/mirror-*.js.
BSKY_IDENTIFIER=dame.is
# Alias of BSKY_IDENTIFIER (checked if BSKY_IDENTIFIER is unset).
ATP_IDENTIFIER=dame.is
# App password (NOT your account password) — create one in Bluesky settings.
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Alias of BSKY_APP_PASSWORD (checked if BSKY_APP_PASSWORD is unset).
ATP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- AT Protocol credentials (portfolio + guestbook scripts) ------------------
# The DAME_*/APP_* aliases used by scripts/portfolio/* and
# scripts/create-guestbook.mjs. Same credentials, different variable names.
DAME_HANDLE=dame.is
DAME_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Optional explicit PDS service URL; auto-resolved from the handle when unset.
DAME_PDS_SERVICE=https://pds.example.com
# Optional: at:// URI of the portfolio publication for the creating-work
# migration (defaults to PORTFOLIO_PUBLICATION in src/config.js).
DAME_PORTFOLIO_PUBLICATION=at://did:plc:xxxx/site.standard.publication/xxxx

# --- Cron / deploy protection (api/) ------------------------------------------
# Shared secret gating the cron endpoints (api/mirror-mothing.js,
# api/mirror-arena.js, api/rebuild.js). Vercel sends it on scheduled runs.
CRON_SECRET=replace-with-a-long-random-string
# Vercel deploy-hook URL POSTed by api/rebuild.js to trigger a production build
# (Settings -> Git -> Deploy Hooks). See README "Deploy hook setup".
DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxx/xxxx

# --- are.na mirror (api/arena.js, api/mirror-arena.js, arena-mirror/) ----------
# Personal access token for the are.na API (reads the mirrored channels).
ARENA_ACCESS_TOKEN=your-arena-access-token
# Aliases of ARENA_ACCESS_TOKEN (checked in this order if the first is unset).
ARENA_TOKEN=your-arena-access-token
ARENA_API_KEY=your-arena-access-token
# are.na username to mirror (defaults to ARENA_USER in src/config.js).
ARENA_MIRROR_USER=dame
# Which blocks to mirror: 'connected' (default) or 'created'.
ARENA_MIRROR_SCOPE=connected
# How block media is handled: 'references' (default) or 'blobs'.
ARENA_MIRROR_MEDIA=references
# Set truthy to include private channels in the mirror.
ARENA_MIRROR_INCLUDE_PRIVATE=false
# Max size (in MB) for a single mirrored media blob.
ARENA_MIRROR_MAX_BLOB_MB=10

# --- Portfolio image extraction (scripts/portfolio/extract.mjs) ---------------
# Max width (px) to downscale extracted images to. Default 2560; 3840 for
# full-resolution archival.
MAX_IMG_WIDTH=2560

# --- Provided automatically by Vercel (do not set manually) -------------------
# VERCEL_GIT_COMMIT_SHA  — read by vite.config.js to key the build id.
