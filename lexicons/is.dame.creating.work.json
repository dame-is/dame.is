{
  "lexicon": 1,
  "id": "is.dame.creating.work",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "slug", "createdAt"],
        "properties": {
          "title":     { "type": "string", "maxLength": 300 },
          "slug":      { "type": "string", "maxLength": 200 },
          "category":  { "type": "string", "maxLength": 64 },
          "tags":      {
            "type": "array",
            "items": { "type": "string", "maxLength": 64 }
          },
          "summary":   { "type": "string", "maxLength": 2000 },
          "content":   {
            "type": "unknown",
            "description": "A pub.leaflet.content value: { $type, pages: [{ $type, blocks: [...] }] }. Matches the body format used by site.standard.document and pub.leaflet.document so the renderer is shared."
          },
          "createdAt": { "type": "string", "format": "datetime" },
          "updatedAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
